{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "edit": {
      "*": "allow",
      "flake.lock": "ask",
      "*.sops": "deny",
      "*.env*": "deny",
      "*.age": "deny"
    },
    "bash": {
      "*": "allow",
      "just build": "allow",
      "just update": "allow",
      "just update-check": "allow",
      "nix build *": "allow",
      "nix flake *": "allow",
      "rm -rf /*": "deny",
      "rm -rf ~*": "deny",
      "docker volume rm *": "deny"
    }
  },
  "mcp": {
    "nix": {
      "type": "local",
      "command": ["nix", "run", "github:utensils/mcp-nixos"],
      "enabled": true
    }
  }
}
